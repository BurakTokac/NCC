@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/SiteLayout.cshtml";
}

<div class="row">
    <div class="col-md-6 col-lg-3">
        <div class="card card-translucent">
            <div class="card-header bg-NCCOrange text-white">
                <h2>Admissions</h2>
            </div>
            <div class="card-body">
                <p>
                    Apply for fall, spring, or summer terms. Our admissions team is here to guide you through application requirements, deadlines, and financial aid options so you can make an informed decision.
                </p>
                <p>
                    Schedule a campus tour or attend an open house to meet faculty and current students. Virtual visits and admissions counselors are available for out-of-area applicants.
                </p>
                <p>
                    Learn about scholarships, grants, and payment plans. Start your application online today and check your application status through the student portal.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card">
            <div class="card-header bg-NCCOrange text-white">
                <h2>Academics</h2>
            </div>
            <div class="card-body">
                <p>
                    Explore over 50 degree and certificate programs across liberal arts, STEM, business, and emerging technologies. Our curriculum emphasizes hands-on learning and career readiness.
                </p>
                <p>
                    Meet with academic advisors to choose majors, plan semesters, and map transfer pathways to four-year institutions. We offer evening and online courses for flexible scheduling.
                </p>
                <p>
                    Access tutoring, academic workshops, and faculty office hours to support your success in coursework and in preparing for internships and transfer opportunities.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card">
            <div class="card-header bg-NCCOrange text-white">
                <h2>Student Life</h2>
            </div>
            <div class="card-body">
                <p>
                    Get involved with student clubs, cultural organizations, and leadership programs that enhance campus community and personal growth. There’s something for every interest.
                </p>
                <p>
                    Attend campus events, concerts, and career fairs. Our student activities calendar highlights opportunities to network, volunteer, and build lifelong connections.
                </p>
                <p>
                    Learn about housing options, health and wellness services, and student support programs designed to foster a safe, inclusive, and vibrant campus experience.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3">
        <div class="card">
            <div class="card-header bg-NCCOrange text-white">
                <h2>Support & Resources</h2>
            </div>
            <div class="card-body">
                <p>
                    Access the library, research databases, and study spaces. Our librarians and resource specialists help with research, citations, and finding course materials.
                </p>
                <p>
                    Take advantage of counseling services, disability accommodations, and student success coaching to support mental health and academic progress throughout your studies.
                </p>
                <p>
                    Visit career services for resume review, interview preparation, and job placements. We connect students with internships, employers, and alumni mentoring programs.
                </p>
            </div>
        </div>
    </div>
</div>