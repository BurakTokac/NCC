@{
    ViewBag.Title = "About";
    Layout = "~/Views/Shared/SiteLayout.cshtml";
}

<div class="row mt-4">
    <div class="col-12 col-md-10 col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header bg-NCCOrange text-white">
                <h2>About Nassau Community College</h2>
            </div>
            <div class="card-body">
                <p>
                    Nassau Community College provides accessible, high-quality education to a diverse student body.
                    We offer associate degrees, certificate programs, and continuing education designed to support academic
                    success, career preparation, and lifelong learning.
                </p>

                <p>
                    Our faculty combine classroom instruction with hands-on learning, advising, and transfer support to
                    help students meet their goals. Whether you are starting college for the first time, returning to
                    complete a degree, or pursuing professional development, NCC supports your path forward.
                </p>

                <p>
                    Learn more about programs, admissions, and campus services via the navigation links or contact the
                    college directly from the Contact page.
                </p>
            </div>
        </div>
    </div>
</div>