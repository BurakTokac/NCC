@{
    ViewBag.Title = "FAQ";
    Layout = "~/Views/Shared/SiteLayout.cshtml";
}

<div class="row mt-4">
    <div class="col-12 col-md-10 col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header bg-NCCOrange text-white">
                <h2>Frequently Asked Questions</h2>
            </div>
            <div class="card-body">
                <h4>How do I apply?</h4>
                <p>
                    Start an application through the Admissions page. You can also contact Admissions for guidance
                    on requirements and deadlines.
                </p>

                <h4>What programs are offered?</h4>
                <p>
                    NCC offers associate degrees and certificates across liberal arts, STEM, business, and vocational fields.
                    Visit the Academics section for program details.
                </p>

                <h4>Can I transfer to a four-year college?</h4>
                <p>
                    Yes. NCC has transfer agreements with many four-year institutions and provides advising to help you
                    plan a successful transfer pathway.
                </p>

                <h4>How do I get financial aid?</h4>
                <p>
                    Complete the FAFSA and contact the Financial Aid office. Information about scholarships and payment
                    options is available on the college website.
                </p>

                <h4>Who do I contact for technical support?</h4>
                <p>
                    For website or account issues, contact IT support at <a href="mailto:itsupport@ncc.edu">itsupport@ncc.edu</a>
                    or call the main phone number.
                </p>
            </div>
        </div>
    </div>
</div>